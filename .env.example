# Copy to .env.local and fill in. .env.local is gitignored.
#
# All env vars used by this project, in one place. If something below
# is empty in dev, the code falls back to deterministic stub data so
# pages still render — no envs are strictly required to boot the app.

# ── Supabase auth (staff login on /admin) ─────────────────────────────
# Required for production. In dev with these absent, the proxy + AdminShell
# skip the auth check so designers can iterate without secrets. Set up:
#   1. Create a Supabase project (https://supabase.com/dashboard)
#   2. Auth → Providers → enable Google, paste your OAuth client ID/secret
#   3. Auth → URL Configuration → add http://localhost:3002/auth/callback
#      and https://yourdomain.com/auth/callback to the redirect allowlist
#   4. Copy the project URL and the **publishable** anon key below
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ── SerpApi (Google Shopping comparable-price search) ─────────────────
# Used by /api/comparables and the Add Item flow. Falls back to a
# bundled fixture in dev when missing. Get a key at https://serpapi.com.
SERPAPI_KEY=

# ── (Future) Stripe ───────────────────────────────────────────────────
# Not yet wired. When the storefront takes real money, add:
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# ── (Future) AI staging ───────────────────────────────────────────────
# Not yet wired. When the catalog runs AI hero photos, add:
# GEMINI_API_KEY=     # or whichever model the safety-net report picks

# ── Resend (inquiry form email delivery) ──────────────────────────────
# REQUIRED in production. The InquiryForm on /four-squared,
# /builders-corner, /builders-corner/consultation submits leads via the
# Resend HTTP API to INQUIRY_TO_EMAIL. Without RESEND_API_KEY the form
# still works in dev (writes to data/inquiries.json) but will silently
# log + show a friendly error in production.
#
# Setup (10 min):
#   1. https://resend.com → sign up (free tier covers our volume)
#   2. Add and verify your sending domain, OR use the included
#      onboarding@resend.dev sender for testing
#   3. Paste the API key + the destination address below
RESEND_API_KEY=
INQUIRY_TO_EMAIL=pricelessbuildingcenter@gmail.com
# INQUIRY_FROM_EMAIL=Price-Less Building <inquiries@yourdomain.com>

# ── Production gates ──────────────────────────────────────────────────
# Set PUBLIC_ADMIN_ENABLED=1 ONLY when Supabase auth is also wired and
# the /admin section is ready for the public internet. Without this var,
# /admin/* returns 404 in production (NODE_ENV=production) even if the
# Supabase vars are present, so we don't accidentally leak admin during
# pre-launch deploys.
# PUBLIC_ADMIN_ENABLED=1

# ── (Future) Stripe ───────────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# ── (Future) Google Places (live reviews on TrustBlock) ───────────────
# GOOGLE_PLACES_API_KEY=
# GOOGLE_PLACES_ID=
